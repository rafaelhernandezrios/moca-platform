# --- Desarrollo local ---
# El frontend llama al backend vía /api (proxy de Vite -> localhost:3000).
# Así funciona en localhost, en la red local y detrás de un túnel HTTPS sin mixed content.
VITE_API_URL=/api

# --- Producción (Vercel) ---
# En el proyecto de Vercel del frontend, define VITE_API_URL con la URL del backend, p.ej.:
#   VITE_API_URL=https://moca-backend.vercel.app
# (NO uses /api en producción salvo que configures un rewrite hacia el backend.)
